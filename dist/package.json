{
  "name": "@adsq/angular-signal-store",
  "version": "0.1.0",
  "description": "Angular SignalStore — reactive, proxy-based store with fine-grained signal wake. Uses jsnq (separate dependency) for queries/mutations.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/synestiqx/angular-signal-store.git"
  },
  "homepage": "https://github.com/synestiqx/angular-signal-store#readme",
  "bugs": "https://github.com/synestiqx/angular-signal-store/issues",
  "type": "module",
  "module": "fesm2022/adsq-angular-signal-store.mjs",
  "exports": {
    ".": {
      "types": "./index.d.ts",
      "default": "./fesm2022/adsq-angular-signal-store.mjs"
    },
    "./devtools": {
      "types": "./devtools/index.d.ts",
      "default": "./fesm2022/adsq-angular-signal-store-devtools.mjs"
    },
    "./package.json": {
      "default": "./package.json"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "peerDependencies": {
    "@angular/core": ">=20.0.0 <23.0.0",
    "rxjs": "^6.5.3 || ^7.4.0",
    "@adsq/jsnq": "^0.1.0"
  },
  "keywords": [
    "angular",
    "signal",
    "store",
    "state-management",
    "reactive",
    "proxy",
    "@adsq/jsnq"
  ],
  "license": "MIT",
  "typings": "index.d.ts",
  "dependencies": {
    "tslib": "^2.3.0"
  }
}