{
  "name": "angular-signal-store",
  "version": "0.1.0",
  "description": "Angular SignalStore — reactive, proxy-based store with fine-grained signal wake. Uses jsnq (separate dependency) for queries/mutations.",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/synestiqx/angular-signal-store.git"
  },
  "homepage": "https://github.com/synestiqx/angular-signal-store#readme",
  "bugs": "https://github.com/synestiqx/angular-signal-store/issues",
  "type": "module",
  "module": "./dist/fesm2022/synestiqx-angular-signal-store.mjs",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/fesm2022/synestiqx-angular-signal-store.mjs"
    },
    "./devtools": {
      "types": "./dist/devtools/index.d.ts",
      "default": "./dist/fesm2022/synestiqx-angular-signal-store-devtools.mjs"
    },
    "./package.json": {
      "default": "./package.json"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "ng-packagr -p ng-package.json -c tsconfig.lib.json",
    "prepack": "npm run build",
    "typecheck": "tsc --noEmit",
    "test:smoke": "bun test/smoke.ts",
    "bench:store": "bun test/store-throughput-bench.ts"
  },
  "peerDependencies": {
    "@angular/core": ">=20.0.0 <23.0.0",
    "jsnq": "^0.1.0",
    "rxjs": "^6.5.3 || ^7.4.0"
  },
  "devDependencies": {
    "@angular/compiler": "20.3.26",
    "@angular/compiler-cli": "20.3.26",
    "@angular/core": "20.3.26",
    "jsnq": "^0.1.0",
    "ng-packagr": "20.3.2",
    "rxjs": "7.8.2",
    "tslib": "^2.8.1",
    "typescript": "5.8.3"
  },
  "keywords": [
    "angular",
    "signal",
    "store",
    "state-management",
    "reactive",
    "proxy",
    "jsnq"
  ],
  "license": "MIT"
}
