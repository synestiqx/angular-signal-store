{
  "name": "@synestiqx/angular-signal-store",
  "version": "0.1.0",
  "description": "Angular SignalStore — reactive, proxy-based store with fine-grained signal wake. Uses @synestiqx/jsondb (separate dependency) for queries/mutations.",
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "import": "./src/index.ts"
    }
  },
  "files": [
    "src",
    "dist",
    "README.md"
  ],
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test:smoke": "bun test/smoke.ts"
  },
  "peerDependencies": {
    "@angular/core": "^20.0.0",
    "rxjs": "^7.8.0",
    "@synestiqx/jsondb": "^0.1.0"
  },
  "devDependencies": {
    "@synestiqx/jsondb": "file:../jsondb_git",
    "@angular/core": "^20.0.0",
    "rxjs": "^7.8.0",
    "typescript": "^5.8.0"
  },
  "keywords": [
    "angular",
    "signal",
    "store",
    "state-management",
    "reactive",
    "proxy",
    "jsondb"
  ],
  "license": "MIT"
}
